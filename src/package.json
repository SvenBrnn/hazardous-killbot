    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/memory-cache": "^0.2.6",
    "@types/open-graph-scraper": "^5.2.3",
